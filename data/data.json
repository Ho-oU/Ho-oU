        {
          "id": "pad-thai",
          "name": "10 Minute Chicken Pad Thai",
          "time": "25 Min",
          "servings": 4,
          "calories": 415,
          "ingredients": [
            {
              "section": "Sauce",
              "items": [
                "2 tablespoons fish sauce",
                "2 tablespoons lime juice",
                "1 tablespoon brown sugar",
                "1 tablespoon soy sauce"
              ]
            },
            {
              "section": "Stir-fry",
              "items": [
                "200g rice noodles",
                "2 chicken breasts, sliced",
                "2 eggs, lightly beaten",
                "1 cup bean sprouts",
                "2 green onions, chopped",
                "¼ cup peanuts, crushed"
              ]
            }
          ],
          "instructions": "1. Cook noodles according to package directions. Drain.\n2. Mix fish sauce, lime juice, sugar, soy sauce in a bowl.\n3. Stir-fry chicken until cooked. Push aside, scramble eggs.\n4. Add noodles and sauce, toss.\n5. Remove from heat, add bean sprouts and onions.\n6. Serve with crushed peanuts."
        },
        {
          "id": "air-fryer",
          "name": "Air Fryer Chicken Breast",
          "time": "20 Min",
          "servings": 2,
          "calories": 320,
          "ingredients": [
            {
              "section": "Main",
              "items": [
                "2 boneless skinless chicken breasts",
                "1 tbsp olive oil",
                "1 tsp paprika",
                "½ tsp garlic powder",
                "Salt and pepper"
              ]
            }
          ],
          "instructions": "1. Preheat air fryer to 375°F.\n2. Rub chicken with oil and spices.\n3. Air fry 12-15 min, flipping halfway.\n4. Rest 5 min before serving."
        }
      ]
